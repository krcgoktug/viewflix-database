graph VIEWFLIX_ER {
  graph [rankdir=LR, splines=spline, overlap=false, sep="+22", nodesep=0.5, ranksep=1.1,
         fontname="Helvetica-Bold", fontsize=22,
         label="VIEWFLIX - Entity Relationship Diagram", labelloc="t"];
  node [shape=record, style="filled", fontname="Helvetica", fontsize=12, penwidth=1.4];
  edge [dir=none, color="#555555", penwidth=1.3, fontname="Helvetica-Bold",
        fontsize=13, fontcolor="#b30000", labeldistance=1.6, labelangle=0];

  // ---------- Strong entities (single border, blue) ----------
  users              [fillcolor="#cfe2f3", label="{USERS|user_id (PK)\l|email\l|country\l|account_status\l}"];
  subscription_plans [fillcolor="#cfe2f3", label="{SUBSCRIPTION_PLANS|plan_id (PK)\l|plan_name\l|monthly_price\l|max_screens\l}"];
  subscriptions      [fillcolor="#cfe2f3", label="{SUBSCRIPTIONS|subscription_id (PK)\l|user_id (FK)\l|plan_id (FK)\l|status\l|payment_status\l}"];
  content            [fillcolor="#cfe2f3", label="{CONTENT|content_id (PK)\l|title\l|content_type\l|imdb_rating\l}"];
  genres             [fillcolor="#cfe2f3", label="{GENRES|genre_id (PK)\l|genre_name\l}"];
  people             [fillcolor="#cfe2f3", label="{PEOPLE|person_id (PK)\l|full_name\l|nationality\l}"];
  watch_history      [fillcolor="#cfe2f3", label="{WATCH_HISTORY|history_id (PK)\l|user_id (FK)\l|content_id (FK)\l|progress_percent\l}"];
  reviews            [fillcolor="#cfe2f3", label="{REVIEWS|review_id (PK)\l|user_id (FK)\l|content_id (FK)\l|rating\l}"];

  // ---------- Weak / associative entities (double border, orange) ----------
  content_genres [fillcolor="#fde9d9", peripheries=2, label="{CONTENT_GENRES (weak)|content_id (PK, FK)\l|genre_id (PK, FK)\l}"];
  content_cast   [fillcolor="#fde9d9", peripheries=2, label="{CONTENT_CAST (weak)|content_id (PK, FK)\l|person_id (PK, FK)\l|cast_role (PK)\l|character_name\l}"];
  favorites      [fillcolor="#fde9d9", peripheries=2, label="{FAVORITES (weak)|user_id (PK, FK)\l|content_id (PK, FK)\l|added_date\l}"];

  // ---------- Relationships (1 : N) ----------
  users -- subscriptions          [taillabel="1", headlabel="N"];
  subscription_plans -- subscriptions [taillabel="1", headlabel="N"];
  users -- watch_history          [taillabel="1", headlabel="N"];
  content -- watch_history        [taillabel="1", headlabel="N"];
  users -- reviews                [taillabel="1", headlabel="N"];
  content -- reviews              [taillabel="1", headlabel="N"];
  content -- content_genres       [taillabel="1", headlabel="N"];
  genres -- content_genres        [taillabel="1", headlabel="N"];
  content -- content_cast         [taillabel="1", headlabel="N"];
  people -- content_cast          [taillabel="1", headlabel="N"];
  users -- favorites              [taillabel="1", headlabel="N"];
  content -- favorites            [taillabel="1", headlabel="N"];
}
